# ── IA / Analyse ────────────────────────────────────────────────────────────────
# Gemini API — free tier, 100 req/jour sur Gemini 2.5 Pro
# Clé : https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Modèle Gemini (override si le nom a changé)
GEMINI_MODEL=gemini-2.5-pro

# Groq API — free tier, 1000 req/jour sur Llama 3.3 70B
# Clé : https://console.groq.com
GROQ_API_KEY=

# ── Alertes email (SMTP) ────────────────────────────────────────────────────────
# Fournisseur recommandé : Gmail avec mot de passe d'application (2FA requis)
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton.email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
ALERT_EMAIL_TO=destinataire@gmail.com

# ── Telegram ────────────────────────────────────────────────────────────────────
# 1. Crée un bot via @BotFather sur Telegram → copie le token
# 2. Envoie /start à ton bot, puis récupère le chat_id :
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=987654321

# ── Discord ─────────────────────────────────────────────────────────────────────
# Dans ton serveur Discord : Paramètres du salon → Intégrations → Webhooks → Nouveau webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
